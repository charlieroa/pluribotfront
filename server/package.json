{
  "name": "plury-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore '**/*.db' --ignore '**/*.db-journal' src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate --schema=src/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema=src/db/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=src/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/db/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=src/db/prisma/schema.prisma",
    "db:migrate:status": "prisma migrate status --schema=src/db/prisma/schema.prisma",
    "ops:prod-check": "tsx src/scripts/prod-check.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@imgly/background-removal-node": "^1.4.5",
    "@prisma/client": "^6.3.0",
    "@types/multer": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "multer": "^2.0.2",
    "sharp": "^0.34.5",
    "typescript": "^5.7.3",
    "uuid": "^11.0.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.12.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.3.0",
    "tsx": "^4.19.2",
    "vitest": "^4.0.18"
  }
}
